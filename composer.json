{
    "name": "ghostcompiler/laravel-hetzner-cloud",
    "version": "1.0.0",
    "description": "Production-ready Laravel SDK for the Hetzner Cloud API",
    "license": "MIT",
    "authors": [
        {
            "name": "Ghost Compiler",
            "email": "info@ghostcompiler.com"
        }
    ],
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3 || ^8.4 || ^8.5",
        "illuminate/support": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9.5 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
        "rector/rector": "^1.0",
        "vimeo/psalm": "^5.9"
    },
    "autoload": {
        "psr-4": {
            "Vendor\\HetznerCloud\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vendor\\HetznerCloud\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vendor\\HetznerCloud\\Providers\\HetznerCloudServiceProvider"
            ],
            "aliases": {
                "Hetzner": "Vendor\\HetznerCloud\\Facades\\Hetzner"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        },
        "audit": {
            "block-insecure": false,
            "ignore": {
                "CVE-2026-48019": "Laravel CRLF injection in default email rule affects dev dependencies and is not used by this package.",
                "GHSA-5vg9-5847-vvmq": "Laravel CRLF injection in default email rule affects dev dependencies and is not used by this package."
            }
        }
    }
}
